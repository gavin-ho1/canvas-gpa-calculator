{
  "manifest_version": 3,
  "name": "Canvas GPA Calculator",
  "version": "2.0",
  "description": "A Chrome Extension that automatically calculates your Canvas grades and GPA",
  "permissions": ["storage"],
  
  "browser_specific_settings": {
    "gecko": {
      "id": "canvas-gpa-calculator@gavin-ho",
      "data_collection_permissions": { "required": ["none"] }
    }
  },

  "action": {
    "default_popup": "menus/options.html",
    "default_icon": "logo.png",
    "default_title": "Calculator"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "scripts": ["scripts/browser-polyfill.min.js", "scripts/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://*.instructure.com/courses/*/grades*","http://*.instructure.com/courses/*/grades*","http://*.instructure.com/*", "https://*.instructure.com/*"],
      "exclude_matches" : ["https://*.instructure.com/*/assignments/*","http://*.instructure.com/*/assignments/*"],
      "js": ["scripts/browser-polyfill.min.js", "scripts/content.js"],
      "run_at" : "document_idle"
    }
  ]
}

